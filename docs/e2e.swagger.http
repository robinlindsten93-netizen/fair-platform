@baseUrl = http://localhost:5001
@riderPhone = +46700000001
@driverPhone = +46700000002
@otpCode = 123456

###
# =================
# 0) OTP Rider
# =================
POST {{baseUrl}}/api/v1/auth/otp/request
Content-Type: application/json

{
  "phone": "{{riderPhone}}"
}

###
# @name riderVerify
POST {{baseUrl}}/api/v1/auth/otp/verify
Content-Type: application/json

{
  "phone": "{{riderPhone}}",
  "code": "{{otpCode}}"
}

###
# @name riderMe
GET {{baseUrl}}/api/v1/me
Authorization: Bearer {{riderVerify.response.body.access_token}}

###
# Grant Rider role (DEV)
# OBS: Om /me inte returnerar "userId" utan t.ex. "id" eller "subject/sub"
# ändra raden nedan till rätt property.
POST {{baseUrl}}/api/v1/dev/roles/grant
Authorization: Bearer {{riderVerify.response.body.access_token}}
Content-Type: application/json

{
  "userId": "{{riderMe.response.body.userId}}",
  "role": "Rider"
}

###
GET {{baseUrl}}/api/v1/me
Authorization: Bearer {{riderVerify.response.body.access_token}}

###
# =================
# 1) OTP Driver
# =================
POST {{baseUrl}}/api/v1/auth/otp/request
Content-Type: application/json

{
  "phone": "{{driverPhone}}"
}

###
# @name driverVerify
POST {{baseUrl}}/api/v1/auth/otp/verify
Content-Type: application/json

{
  "phone": "{{driverPhone}}",
  "code": "{{otpCode}}"
}

###
# @name driverMe
GET {{baseUrl}}/api/v1/me
Authorization: Bearer {{driverVerify.response.body.access_token}}

###
POST {{baseUrl}}/api/v1/dev/roles/grant
Authorization: Bearer {{driverVerify.response.body.access_token}}
Content-Type: application/json

{
  "userId": "{{driverMe.response.body.userId}}",
  "role": "Driver"
}

###
GET {{baseUrl}}/api/v1/me
Authorization: Bearer {{driverVerify.response.body.access_token}}

###
# =================
# 2) Driver online
# =================
POST {{baseUrl}}/api/v1/driver/me/availability
Authorization: Bearer {{driverVerify.response.body.access_token}}
Content-Type: application/json

{
  "isOnline": true
}

###
GET {{baseUrl}}/api/v1/driver/me
Authorization: Bearer {{driverVerify.response.body.access_token}}

###
# =================
# 3) Create Trip (Quoted)
# =================
# Sätt en riktig quoteToken här:
@quoteToken = PASTE_QUOTE_TOKEN_HERE

###
# @name createTrip
POST {{baseUrl}}/api/v1/trips
Authorization: Bearer {{riderVerify.response.body.access_token}}
Content-Type: application/json

{
  "pickupLat": 59.3293,
  "pickupLng": 18.0686,
  "dropoffLat": 59.3326,
  "dropoffLng": 18.0649,
  "mode": 0,
  "quoteToken": "{{quoteToken}}"
}

###
GET {{baseUrl}}/api/v1/trips/{{createTrip.response.body.tripId}}
Authorization: Bearer {{riderVerify.response.body.access_token}}

###
# =================
# 4) Request Trip (dispatch kick)
# =================
POST {{baseUrl}}/api/v1/trips/{{createTrip.response.body.tripId}}/request
Authorization: Bearer {{riderVerify.response.body.access_token}}
Content-Type: application/json

{
  "quoteToken": "{{quoteToken}}"
}

###
GET {{baseUrl}}/api/v1/trips/my/active
Authorization: Bearer {{riderVerify.response.body.access_token}}

###
# =================
# 5) Driver offers
# =================
# @name myOffers
GET {{baseUrl}}/api/v1/dispatch/offers/my
Authorization: Bearer {{driverVerify.response.body.access_token}}

###
# =================
# 6) Accept offer -> trip Accepted
# =================
# OBS: Detta tar första offret i listan. Om din DTO heter annat än offerId, ändra.
POST {{baseUrl}}/api/v1/dispatch/offers/{{myOffers.response.body[0].offerId}}/accept
Authorization: Bearer {{driverVerify.response.body.access_token}}
Content-Type: application/json

{}

###
GET {{baseUrl}}/api/v1/trips/driver/my/active
Authorization: Bearer {{driverVerify.response.body.access_token}}

###
GET {{baseUrl}}/api/v1/trips/my/active
Authorization: Bearer {{riderVerify.response.body.access_token}}

###
# =================
# 7) Lifecycle: Arrive -> Start -> Complete
# =================
POST {{baseUrl}}/api/v1/trips/{{createTrip.response.body.tripId}}/arrive
Authorization: Bearer {{driverVerify.response.body.access_token}}
Content-Type: application/json

{}

###
POST {{baseUrl}}/api/v1/trips/{{createTrip.response.body.tripId}}/start
Authorization: Bearer {{driverVerify.response.body.access_token}}
Content-Type: application/json

{}

###
POST {{baseUrl}}/api/v1/trips/{{createTrip.response.body.tripId}}/complete
Authorization: Bearer {{driverVerify.response.body.access_token}}
Content-Type: application/json

{}

###
# =================
# 8) Read models: history
# =================
GET {{baseUrl}}/api/v1/trips/my
Authorization: Bearer {{riderVerify.response.body.access_token}}

###
GET {{baseUrl}}/api/v1/trips/driver/my
Authorization: Bearer {{driverVerify.response.body.access_token}}